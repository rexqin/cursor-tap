{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/api",
  "tags": ["type:app", "lang:go"],
  "targets": {
    "build": {
      "executor": "@naxodev/gonx:build",
      "outputs": ["{workspaceRoot}/dist/tap-api"],
      "options": {
        "main": "main.go",
        "outputPath": "dist/tap-api"
      },
      "cache": true,
      "inputs": [
        "{workspaceRoot}/go.mod",
        "{workspaceRoot}/go.sum",
        "{workspaceRoot}/internal/**/*.go",
        "{projectRoot}/**/*.go"
      ]
    },
    "dev": {
      "executor": "@naxodev/gonx:serve",
      "continuous": true,
      "options": {
        "main": "main.go",
        "args": ["start"]
      }
    },
    "serve": {
      "executor": "@naxodev/gonx:serve",
      "continuous": true,
      "options": {
        "main": "main.go",
        "args": ["start"]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "go test ./tests/apiserver/... ./tests/recordstore/... ./tests/notify/...",
        "cwd": "{workspaceRoot}"
      }
    },
    "lint": {
      "executor": "@naxodev/gonx:lint",
      "cache": true,
      "options": {
        "main": "main.go"
      }
    }
  }
}
