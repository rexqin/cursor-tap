{
  "name": "proto",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/proto",
  "tags": ["type:lib", "lang:proto"],
  "targets": {
    "generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "buf generate",
        "cwd": "packages/proto"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/**/*.proto",
        "{projectRoot}/buf.yaml",
        "{projectRoot}/buf.gen.yaml",
        "{projectRoot}/buf.lock"
      ],
      "outputs": ["{projectRoot}/gen"]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "buf generate",
        "cwd": "packages/proto"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/**/*.proto",
        "{projectRoot}/buf.yaml",
        "{projectRoot}/buf.gen.yaml",
        "{projectRoot}/buf.lock"
      ],
      "outputs": ["{projectRoot}/gen"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "buf lint",
        "cwd": "packages/proto"
      },
      "cache": true
    }
  }
}
