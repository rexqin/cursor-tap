{
  "name": "tap",
  "$schema": "node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": ".",
  "tags": ["type:app", "lang:go"],
  "targets": {
    "build": {
      "executor": "@naxodev/gonx:build",
      "outputs": ["{options.outputPath}"],
      "dependsOn": ["proto:build"],
      "options": {
        "main": "cmd/cursor-tap/main.go",
        "outputPath": "dist/tap"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/go.mod",
        "{projectRoot}/go.sum",
        "{projectRoot}/**/*.go",
        "!{projectRoot}/cursor_proto/**"
      ]
    },
    "serve": {
      "executor": "@naxodev/gonx:serve",
      "continuous": true,
      "options": {
        "main": "cmd/cursor-tap/main.go",
        "args": [
          "start",
          "--http-parse",
          "--http-record",
          "../../access.log"
        ]
      }
    },
    "dev": {
      "executor": "@naxodev/gonx:serve",
      "continuous": true,
      "options": {
        "main": "cmd/cursor-tap/main.go",
        "args": [
          "start",
          "--http-parse",
          "--http-record",
          "../../access.log"
        ]
      }
    },
    "test": {
      "executor": "@naxodev/gonx:test",
      "cache": true
    },
    "lint": {
      "executor": "@naxodev/gonx:lint",
      "cache": true
    },
    "tidy": {
      "executor": "@naxodev/gonx:tidy"
    }
  }
}
